/* whoimet — global styles (warm networking palette) */
page {
  --bg:#fbf7f4; --card:#ffffff; --ink:#1d1a19; --sub:#6f6864; --line:#efe7e1;
  --brand:#f76b4b; --brand2:#2f6f6a; --ok:#2f8f5b;
  background: var(--bg);
  color: var(--ink);
  font-size: 30rpx;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", Helvetica, sans-serif;
}
view, text { box-sizing: border-box; }

.wrap { padding: 0 32rpx; }
.hero { padding: 28rpx 8rpx 8rpx; }
.hero .h1 { font-size: 46rpx; font-weight: 800; letter-spacing: -1rpx; }
.hero .p { color: var(--sub); font-size: 27rpx; margin-top: 8rpx; }

.btn {
  background: var(--brand); color: #fff; font-weight: 700; font-size: 32rpx;
  border-radius: 26rpx; padding: 26rpx; text-align: center; line-height: 1.2;
}
.btn.sec { background: var(--card); color: var(--ink); border: 2rpx solid var(--line); }
.btn[disabled] { opacity: .5; }
.btn::after { border: none; }

.card {
  background: var(--card); border: 2rpx solid var(--line); border-radius: 30rpx;
  padding: 28rpx; box-shadow: 0 8rpx 30rpx rgba(30,20,15,.06);
}

.field { margin: 18rpx 0; }
.field .label { font-size: 25rpx; font-weight: 700; color: var(--sub); margin-bottom: 10rpx; }
.input {
  background: var(--bg); border: 2rpx solid var(--line); border-radius: 20rpx;
  padding: 22rpx 26rpx; font-size: 30rpx;
}

.sec-t { font-size: 24rpx; letter-spacing: 2rpx; text-transform: uppercase; color: var(--sub); font-weight: 700; margin: 34rpx 8rpx 16rpx; }
.muted { color: var(--sub); font-size: 25rpx; }
.center { text-align: center; }

.avatar {
  width: 84rpx; height: 84rpx; border-radius: 50%; background: var(--brand); color: #fff;
  display: flex; align-items: center; justify-content: center; font-weight: 800; overflow: hidden; flex: none;
}
.avatar image { width: 100%; height: 100%; }

.empty { border: 2rpx dashed var(--line); border-radius: 30rpx; padding: 60rpx 30rpx; text-align: center; color: var(--sub); }
.empty .e { font-size: 60rpx; margin-bottom: 14rpx; }

.row { display: flex; align-items: center; gap: 20rpx; }
.grow { flex: 1; min-width: 0; }
.ell { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
