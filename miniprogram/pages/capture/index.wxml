<view class="wrap">
  <block wx:if="{{!photo}}">
    <view class="kicker" style="margin-top:20rpx">今天</view>
    <view class="hero" style="border-bottom:none; padding-bottom:10rpx; margin-bottom:6rpx">
      <view class="h1">今天遇见了谁？</view>
    </view>
    <view class="btn-row" style="margin:10rpx 0 34rpx">
      <button class="btn" bindtap="chooseCamera">📷 拍一张</button>
      <button class="btn ghost" bindtap="chooseAlbum">🖼️ 从相册选</button>
    </view>

    <view class="rowcard" bindtap="goMe">
      <view class="ic">↑</view>
      <view class="grow">
        <view class="t">分享我的名片</view>
        <view class="s">别人问"你是谁"的时候，把你的实时名片发过去</view>
      </view>
      <view class="chev">›</view>
    </view>

    <view class="kicker">今天的时刻</view>
    <block wx:if="{{recents.length}}">
      <view class="met card" wx:for="{{recents}}" wx:key="id">
        <image class="met-ph" src="{{item.photo}}" mode="aspectFill"></image>
        <view class="met-b">
          <view class="met-nm ell serif">{{item.note || '未命名时刻'}}</view>
          <view class="met-row">
            <view class="vis {{item.isPublic ? 'pub' : 'priv'}}">{{item.isPublic ? '已公开' : '审核中'}}</view>
            <view class="met-meta">已生成连接卡</view>
          </view>
        </view>
      </view>
    </block>
    <view wx:else class="empty">
      <view class="e">📷</view>
      <view class="t">今天还没有记录</view>
      <view class="s">下次遇到人，点"拍一张"。</view>
    </view>
  </block>

  <block wx:else>
    <view class="kicker" style="margin-top:20rpx">新的时刻</view>
    <view class="card">
      <image class="preview" src="{{photo}}" mode="aspectFill" bindtap="clearPhoto"></image>
      <view class="card-pad">
        <view class="field">
          <view class="label">你的名字（会显示在卡片上）</view>
          <input class="input input-on-card" value="{{name}}" placeholder="怎么称呼你" bindinput="onName" />
        </view>
        <view class="field">
          <view class="label">在哪儿 / 见了谁（可选）</view>
          <input class="input input-on-card" value="{{note}}" placeholder="例如：AI meetup 后喝咖啡" bindinput="onNote" />
        </view>

        <block wx:if="{{!authed}}">
          <button class="btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhone" disabled="{{busy}}" style="width:100%">微信登录（生成你的卡片）</button>
          <view class="muted center" style="margin-top:16rpx">微信登录自动带上已验证的手机号，不用填验证码。</view>
        </block>
        <block wx:else>
          <button wx:if="{{!ready}}" class="btn" bindtap="prepareShare" disabled="{{busy}}" style="width:100%">生成连接卡</button>
          <button wx:else class="btn" open-type="share" style="width:100%">发给对方，Ta 打开就连上 ↗</button>
        </block>
        <button class="btn ghost" bindtap="clearPhoto" style="width:100%; margin-top:18rpx">重拍</button>
      </view>
    </view>
  </block>
</view>
