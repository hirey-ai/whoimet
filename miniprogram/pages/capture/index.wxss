/* moments — web app's meeting card: 4:5 photo, serif caption, tiny meta */
.met { margin-bottom: 32rpx; }
.met-ph { width: 100%; aspect-ratio: 4/5; background: #f0ece2; display: block; }
.met-b { padding: 24rpx 30rpx 30rpx; }
.met-nm { font-weight: 600; font-size: 31rpx; }
.met-row { display: flex; align-items: center; gap: 16rpx; margin-top: 16rpx; }
.met-meta {
  font-size: 20rpx; text-transform: uppercase; letter-spacing: 2.4rpx;
  color: var(--ink-faint); font-weight: 600;
}

/* compose */
.preview { width: 100%; aspect-ratio: 4/5; background: #f0ece2; display: block; }
