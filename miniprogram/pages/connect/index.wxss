.kicker { color: var(--brand); font-weight: 800; letter-spacing: 1rpx; font-size: 24rpx; text-transform: uppercase; text-align: center; margin: 20rpx 0 14rpx; }
.photo { width: 100%; height: 640rpx; border-radius: 36rpx; overflow: hidden; background: var(--line); position: relative; }
.photo-img { width: 100%; height: 100%; }
.photo-fb { position: absolute; left: 0; right: 0; top: 0; bottom: 0; display: flex; align-items: center; justify-content: center; font-size: 120rpx; }

.who-card { margin-top: 24rpx; }
.avatar.big { width: 96rpx; height: 96rpx; font-size: 40rpx; }
.who-nm { font-size: 38rpx; font-weight: 800; }
.who-nm .vf { color: var(--brand2); }
.who-hl { color: var(--sub); font-size: 27rpx; margin-top: 2rpx; }
.note { margin-top: 22rpx; background: var(--bg); border-radius: 20rpx; padding: 22rpx 24rpx; font-size: 29rpx; }
.note-q { color: var(--sub); font-size: 22rpx; font-weight: 700; text-transform: uppercase; letter-spacing: 1rpx; margin-bottom: 6rpx; }

.cta-t { text-align: center; font-size: 40rpx; font-weight: 800; margin: 34rpx 0 6rpx; }
.cta-p { text-align: center; color: var(--sub); font-size: 27rpx; margin-bottom: 26rpx; }
.privacy { text-align: center; color: var(--sub); font-size: 22rpx; margin-top: 24rpx; line-height: 1.5; }

.done { text-align: center; padding: 30rpx 0 10rpx; }
.done-big { font-size: 100rpx; }
.done-h { font-size: 42rpx; font-weight: 800; margin: 12rpx 0 6rpx; }
.done-p { color: var(--sub); font-size: 28rpx; margin-bottom: 26rpx; }
.done-p .b { color: var(--ink); font-weight: 700; }

.foot { text-align: center; color: var(--sub); font-size: 22rpx; margin: 40rpx 0 20rpx; }
