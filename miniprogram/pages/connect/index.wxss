.photo { width: 100%; aspect-ratio: 4/5; background: #f0ece2; position: relative; }
.photo-img { width: 100%; height: 100%; display: block; }
.photo-fb { position: absolute; left: 0; right: 0; top: 0; bottom: 0; display: flex; align-items: center; justify-content: center; font-size: 110rpx; }

.avatar.big { width: 100rpx; height: 100rpx; font-size: 40rpx; }
.who-nm { font-size: 40rpx; font-weight: 600; letter-spacing: -0.5rpx; }
.who-nm .vf { color: var(--blue); }

.note { margin-top: 26rpx; border-top: 1rpx solid var(--line); padding-top: 22rpx; }
.note-q { font-size: 20rpx; text-transform: uppercase; letter-spacing: 2.4rpx; color: var(--ink-faint); font-weight: 600; margin-bottom: 8rpx; }
.note-t { font-size: 29rpx; color: var(--ink-soft); line-height: 1.55; }

.cta-t { text-align: center; font-size: 46rpx; font-weight: 600; letter-spacing: -0.5rpx; margin: 40rpx 0 8rpx; }
.privacy { text-align: center; font-size: 22rpx; margin-top: 28rpx; line-height: 1.55; }

.done { text-align: center; padding: 24rpx 0 8rpx; }
.e-badge {
  width: 108rpx; height: 108rpx; border-radius: 50%; margin: 0 auto;
  background: rgba(52,199,89,.14);
  display: flex; align-items: center; justify-content: center; font-size: 52rpx;
}
.done-h { font-size: 46rpx; font-weight: 600; margin: 20rpx 0 10rpx; }
.done .b { color: var(--ink); font-weight: 600; }

.foot { text-align: center; font-size: 21rpx; margin: 44rpx 0 24rpx; }
