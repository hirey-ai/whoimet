.conn {
  display: flex; align-items: center; gap: 22rpx; padding: 22rpx; margin-bottom: 18rpx;
  background: var(--card); border: 2rpx solid var(--line); border-radius: 26rpx;
}
.conn-nm { font-weight: 700; font-size: 30rpx; }
.mini {
  background: var(--brand); color: #fff; font-weight: 700; font-size: 26rpx;
  border-radius: 16rpx; padding: 12rpx 26rpx; line-height: 1.2; flex: none;
}
.mini::after { border: none; }
