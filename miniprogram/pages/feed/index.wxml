<view class="wrap">
  <view class="kicker" style="margin-top:20rpx">公开动态</view>
  <view class="hero" style="border-bottom:none; padding-bottom:10rpx; margin-bottom:6rpx">
    <view class="h1">大家遇见了<text class="em">谁</text>。</view>
    <view class="p">人们选择公开分享的相遇时刻 — 用他们自己的话，最新在前。</view>
  </view>

  <block wx:if="{{items.length}}">
    <view class="fcard card" wx:for="{{items}}" wx:key="id">
      <view class="fhead">
        <view class="avatar">
          <image wx:if="{{item.avatar}}" src="{{item.avatar}}"></image>
          <text wx:else>{{item.initial}}</text>
        </view>
        <view class="grow">
          <view class="fname serif ell">{{item.names}}</view>
          <view class="fmeta ell">{{item.when}}<text wx:if="{{item.headline}}"> · {{item.headline}}</text></view>
        </view>
      </view>
      <image wx:if="{{item.photo}}" class="fph" src="{{item.photo}}" mode="aspectFill" lazy-load="{{true}}"></image>
      <view wx:if="{{item.cap}}" class="fcap">{{item.cap}}</view>
    </view>
    <view wx:if="{{loading}}" class="muted center" style="padding:24rpx 0">加载中…</view>
    <view wx:elif="{{done}}" class="muted center faint" style="padding:24rpx 0 40rpx">— 到底了 —</view>
  </block>

  <view wx:elif="{{loading}}" class="empty"><view class="e">📷</view><view class="t">加载中…</view></view>
  <view wx:elif="{{error}}" class="empty">
    <view class="e">⚠️</view>
    <view class="t">加载失败</view>
    <view class="s">{{error}}</view>
    <view style="margin-top:26rpx"><button class="btn" bindtap="refresh" style="display:inline-flex; padding:22rpx 60rpx">重试</button></view>
  </view>
  <view wx:else class="empty">
    <view class="e">🫶</view>
    <view class="t">还没有公开的时刻</view>
    <view class="s">拍下你遇到的人，公开分享后会出现在这里。</view>
  </view>
</view>
