/* feed cards — mirror of hirey.ai/met: header row, 4:5 photo, caption, tiny meta */
.hero .em { color: var(--gold); font-style: italic; }
.fcard { margin-bottom: 34rpx; }
.fhead { display: flex; align-items: center; gap: 18rpx; padding: 22rpx 26rpx; }
.fname { font-weight: 600; font-size: 31rpx; }
.fmeta {
  font-size: 20rpx; text-transform: uppercase; letter-spacing: 2rpx;
  color: var(--ink-faint); font-weight: 600; margin-top: 4rpx;
}
.fph { width: 100%; aspect-ratio: 4/5; background: #f0ece2; display: block; }
.fcap { padding: 22rpx 26rpx 26rpx; font-size: 28rpx; color: var(--ink-soft); line-height: 1.55; }
