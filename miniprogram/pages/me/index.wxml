<view class="wrap">
  <view class="kicker" style="margin-top:20rpx">名片</view>
  <view class="hero" style="border-bottom:none; padding-bottom:10rpx; margin-bottom:6rpx">
    <view class="h1">我的 Hi 名片</view>
    <view class="p">这就是你分享出去时，别人看到的样子。</view>
  </view>

  <block wx:if="{{!authed}}">
    <view class="card"><view class="card-pad center" style="padding:56rpx 36rpx">
      <view class="empty" style="padding:0 0 8rpx"><view class="e">👋</view></view>
      <view class="serif" style="font-weight:600; font-size:38rpx; margin:4rpx 0 8rpx">用微信登录 Hi</view>
      <view class="muted" style="margin-bottom:30rpx">自动带上你已验证的手机号，不用填验证码。</view>
      <button class="btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhone" disabled="{{busy}}" style="width:100%">微信登录</button>
    </view></view>
  </block>

  <block wx:else>
    <view class="card"><view class="card-pad">
      <view class="row" style="margin-bottom:14rpx">
        <view class="avatar big">
          <image wx:if="{{avatar}}" src="{{avatar}}"></image>
          <text wx:else>{{nameInitial}}</text>
        </view>
        <view class="grow">
          <view class="serif" style="font-weight:600; font-size:36rpx">{{name || '（还没填名字）'}}</view>
          <view class="muted ell">{{headline || '加一句介绍，让别人知道你是谁'}}</view>
        </view>
      </view>
      <view class="field"><view class="label">名字</view><input class="input input-on-card" value="{{name}}" placeholder="你的名字" bindinput="onName" /></view>
      <view class="field"><view class="label">一句话介绍</view><input class="input input-on-card" value="{{headline}}" placeholder="例如：Acme 创始人 · 上海" bindinput="onHl" /></view>
      <button class="btn" bindtap="save" disabled="{{busy}}" style="width:100%">保存名片</button>
      <view wx:if="{{publicUrl}}" class="pill" bindtap="copyLink">复制我的主页链接</view>
      <button class="btn ghost" bindtap="signOut" style="width:100%; margin-top:20rpx">退出登录</button>
    </view></view>
  </block>
</view>
