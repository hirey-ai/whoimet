<view class="wrap">
  <view class="hero"><view class="h1">我的 Hi 卡片</view><view class="p">这就是你分享出去时，别人看到的样子。</view></view>

  <block wx:if="{{!authed}}">
    <view class="card center" style="padding:50rpx 32rpx">
      <view style="font-size:70rpx">👋</view>
      <view style="font-weight:800; font-size:34rpx; margin:12rpx 0 4rpx">用微信登录 Hi</view>
      <view class="muted" style="margin-bottom:24rpx">自动带上你已验证的手机号，不用填验证码。</view>
      <button class="btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhone" disabled="{{busy}}">微信登录</button>
    </view>
  </block>

  <block wx:else>
    <view class="card">
      <view class="row" style="margin-bottom:8rpx">
        <view class="avatar big">
          <image wx:if="{{avatar}}" src="{{avatar}}"></image>
          <text wx:else>{{nameInitial}}</text>
        </view>
        <view class="grow">
          <view style="font-weight:800; font-size:34rpx">{{name || '（还没填名字）'}}</view>
          <view class="muted ell">{{headline || '加一句介绍，让别人知道你是谁'}}</view>
        </view>
      </view>
      <view class="field"><view class="label">名字</view><input class="input" value="{{name}}" placeholder="你的名字" bindinput="onName" /></view>
      <view class="field"><view class="label">一句话介绍</view><input class="input" value="{{headline}}" placeholder="例如：Acme 创始人 · 上海" bindinput="onHl" /></view>
      <button class="btn" bindtap="save" disabled="{{busy}}">保存卡片</button>
      <view wx:if="{{publicUrl}}" class="pill" bindtap="copyLink">复制我的主页链接</view>
      <button class="btn sec" bindtap="signOut" style="margin-top:20rpx">退出登录</button>
    </view>
  </block>
</view>
